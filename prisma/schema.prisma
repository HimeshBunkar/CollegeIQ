generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  savedColleges SavedCollege[]
  shortlists    Shortlist[]
  comparisons   Comparison[]
  activityLogs  ActivityLog[]
  reviews       Review[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model College {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  logo           String?
  city           String
  state          String
  ownership      Ownership
  fees           Int
  hostelFees     Int            @default(0)
  avgPackage     Float
  highestPackage Float
  rating         Float          @default(0)
  accreditation  String
  nirfRank       Int?
  description    String         @db.Text
  website        String?
  established    Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  courses        Course[]
  placements     Placement[]
  reviews        Review[]
  cutoffs        Cutoff[]
  facilities     Facility[]
  admissions     Admission[]
  savedBy        SavedCollege[]
  shortlistItems ShortlistItem[]

  @@index([state])
  @@index([ownership])
  @@index([nirfRank])
  @@index([rating])
  @@index([fees])
}

enum Ownership {
  GOVERNMENT
  PRIVATE
  DEEMED
  AUTONOMOUS
}

model Course {
  id           String   @id @default(cuid())
  collegeId    String
  name         String
  degree       String
  duration     String
  fees         Int
  seats        Int
  eligibility  String?
  college      College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
  @@index([name])
}

model Placement {
  id           String   @id @default(cuid())
  collegeId    String
  year         Int
  avgPackage   Float
  highestPackage Float
  medianPackage Float?
  placementRate Float
  topRecruiters String[]
  college      College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model Review {
  id        String   @id @default(cuid())
  collegeId String
  userId    String
  rating    Float
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model Cutoff {
  id           String   @id @default(cuid())
  collegeId    String
  exam         ExamType
  category     Category
  gender       Gender
  homeState    String
  year         Int
  openingRank  Int
  closingRank  Int
  course       String
  college      College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([exam, category, gender, homeState])
  @@index([collegeId])
}

enum ExamType {
  JEE_MAIN
  JOSAA
  CSAB
}

enum Category {
  GENERAL
  OBC
  SC
  ST
  EWS
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Facility {
  id        String @id @default(cuid())
  collegeId String
  name      String
  category  String
  available Boolean @default(true)
  college   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model Admission {
  id          String @id @default(cuid())
  collegeId   String
  exam        String
  process     String @db.Text
  eligibility String @db.Text
  seatMatrix  Json
  college     College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model SavedCollege {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
}

model Shortlist {
  id        String          @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ShortlistItem[]
}

model ShortlistItem {
  id          String    @id @default(cuid())
  shortlistId String
  collegeId   String
  shortlist   Shortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  college     College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([shortlistId, collegeId])
}

model Comparison {
  id         String   @id @default(cuid())
  userId     String
  collegeIds String[]
  name       String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
